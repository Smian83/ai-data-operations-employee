# =============================================================================
# AI Data Operations Employee — Environment Configuration
# Copy this file to .env and fill in real values. Never commit .env.
# =============================================================================

# --- Application ---
APP_NAME="AI Data Operations Employee"
APP_ENV=development            # development | staging | production
APP_DEBUG=true

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database (PostgreSQL) ---
POSTGRES_USER=aidataops
POSTGRES_PASSWORD=changeme_dev_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=aidataops
DATABASE_URL=postgresql+psycopg://aidataops:changeme_dev_password@db:5432/aidataops

# --- Logging ---
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json                # json | console

# --- Security (placeholders for future modules) ---
SECRET_KEY=changeme_generate_a_real_secret_key_before_production

# --- JWT / Auth (Module 2) ---
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Task Execution Engine / Worker (Module 4) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=changeme_generate_a_real_fernet_key_before_production
WORKER_ID=worker-1
WORKER_CLAIM_BATCH_SIZE=5
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_HEARTBEAT_INTERVAL_SECONDS=30
WORKER_DEFAULT_TIMEOUT_SECONDS=300
WORKER_DEFAULT_MAX_ATTEMPTS=3
WORKER_RETRY_BASE_DELAY_SECONDS=30
WORKER_RETRY_MAX_DELAY_SECONDS=900
REAPER_POLL_INTERVAL_SECONDS=15
